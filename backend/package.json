{
  "name": "getyourcollege-backend",
  "version": "1.0.0",
  "description": "Standalone REST API backend for getYourCollege.com — Node.js + TypeScript + Express",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.30",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
